    b = bench_new("sqrt");
    bench_run(b, &_bench_sqrt, BENCH_ITERS);
    bench_report(b);

    b = bench_new("abs");
    bench_run(b, &_bench_abs, BENCH_ITERS);
    bench_report(b);

    b = bench_new("amplitude_to_db");
    bench_run(b, &_bench_amp_to_db, BENCH_ITERS);
    bench_report(b);

    b = bench_new("db_to_amplitude");
    bench_run(b, &_bench_db_to_amp, BENCH_ITERS);
    bench_report(b);

    b = bench_new("db_gain_factor");
    bench_run(b, &_bench_db_gain, BENCH_ITERS);
    bench_report(b);

    b = bench_new("midi_to_freq");
    bench_run(b, &_bench_midi_to_freq, BENCH_ITERS);
