    bench_run(b, &_bench_value_as_f64, BENCH_ITERS);
    bench_report(b);

    return 0;
}

# ================================================================
# batch benchmarks (4096 samples)
# ================================================================

var BATCH_SIZE = 4096;
var _batch_buf = 0;

# Pre-fill a buffer of 4096 f64 samples: (i/4096)*2 - 1 => [-1, +1)
fn batch_init() {
    _batch_buf = alloc(BATCH_SIZE * 8);
    var denom = f64_from(BATCH_SIZE);
    var two = f64_from(2);
    var one = f64_from(1);
    var i = 0;
    while (i < BATCH_SIZE) {
        var v = f64_sub(f64_mul(f64_div(f64_from(i), denom), two), one);
        store64(_batch_buf + i * 8, v);
        i = i + 1;
    }
    return 0;
}

fn _bench_batch_sanitize() {
    var i = 0;
    while (i < BATCH_SIZE) {
        sanitize_sample(load64(_batch_buf + i * 8));
        i = i + 1;
    }
    return 0;
}

fn _bench_batch_poly_blep() {
    var dt = f64_div(f64_from(1), f64_from(100));
    var i = 0;
    while (i < BATCH_SIZE) {
        var v = f64_abs(load64(_batch_buf + i * 8));
        poly_blep(v, dt);
        i = i + 1;
    }
    return 0;
}

fn _bench_batch_hypot() {
    var i = 0;
    while (i < BATCH_SIZE - 1) {
        var a = load64(_batch_buf + i * 8);
        var b = load64(_batch_buf + (i + 1) * 8);
        f64_hypot(a, b);
        i = i + 2;
    }
    return 0;
}

fn _bench_batch_sqrt() {
    var i = 0;
    while (i < BATCH_SIZE) {
        f64_sqrt(f64_abs(load64(_batch_buf + i * 8)));
        i = i + 1;
    }
    return 0;
}

fn _bench_batch_round() {
    var i = 0;
    while (i < BATCH_SIZE) {
        var v = f64_mul(load64(_batch_buf + i * 8), f64_from(100));
        f64_round(v);
        i = i + 1;
    }
    return 0;
}

var BATCH_ITERS = 1000;

fn run_batch_benches() {
    println("--- batch (4096 samples) ---");
    batch_init();

    var b = bench_new("sanitize_4096");
    bench_run(b, &_bench_batch_sanitize, BATCH_ITERS);
    bench_report(b);

    b = bench_new("poly_blep_4096");
    bench_run(b, &_bench_batch_poly_blep, BATCH_ITERS);
    bench_report(b);

    b = bench_new("hypot_4096");
    bench_run(b, &_bench_batch_hypot, BATCH_ITERS);
    bench_report(b);

    b = bench_new("sqrt_4096");
    bench_run(b, &_bench_batch_sqrt, BATCH_ITERS);
    bench_report(b);

    b = bench_new("round_4096");
    bench_run(b, &_bench_batch_round, BATCH_ITERS);
    bench_report(b);

    return 0;
}

# ================================================================
# main
# ================================================================

fn main() {
    alloc_init();
    println("=== abaco benchmarks ===");
    run_ntheory_benches();
    run_dsp_benches();
    run_core_benches();
    run_batch_benches();
    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
