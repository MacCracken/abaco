fn _bench_category_name() {
    category_name(CAT_FREQUENCY);
    return 0;
}

fn _bench_category_from_str() {
    category_from_str("viscosity");
    return 0;
}

fn _bench_value_integer() {
    Value_integer(42);
    return 0;
}

fn _bench_value_as_f64() {
    var v = Value_fraction(355, 113);
    Value_as_f64(v);
    return 0;
}

fn run_core_benches() {
    println("--- core ---");

    var b = bench_new("category_name");
    bench_run(b, &_bench_category_name, BENCH_ITERS);
    bench_report(b);

    b = bench_new("category_from_str");
    bench_run(b, &_bench_category_from_str, BENCH_ITERS);
