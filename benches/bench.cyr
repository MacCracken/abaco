    b = bench_new("time_constant");
    bench_run(b, &_bench_time_const, BENCH_ITERS);
    bench_report(b);

    b = bench_new("pan_center");
    bench_run(b, &_bench_pan_center, BENCH_ITERS);
    bench_report(b);

    b = bench_new("crossfade_mid");
