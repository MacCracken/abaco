# abaco benchmarks
# Parity with rust-old/benches/benchmarks.rs (ported modules only)
# Run: cat benches/bench.cyr | cc2 > build/bench && chmod +x build/bench && ./build/bench

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/tagged.cyr"
include "lib/fnptr.cyr"
include "lib/bench.cyr"

include "src/core.cyr"
include "src/ntheory.cyr"
include "src/dsp.cyr"

var BENCH_ITERS = 10000;

# ================================================================
# ntheory benchmarks
# ================================================================

fn _bench_is_prime_small() { is_prime(104729); return 0; }
fn _bench_is_prime_large() { is_prime(999999999989); return 0; }
fn _bench_next_prime() { next_prime(1000000); return 0; }
fn _bench_factor_small() { factor(360); return 0; }
fn _bench_factor_large() { factor(1234567890); return 0; }
fn _bench_totient() { totient(1000000); return 0; }
fn _bench_fibonacci() { fibonacci(92); return 0; }
fn _bench_binomial() { binomial(60, 30); return 0; }

fn run_ntheory_benches() {
    println("--- ntheory ---");

    var b = bench_new("is_prime_small");
    bench_run(b, &_bench_is_prime_small, BENCH_ITERS);
    bench_report(b);

    b = bench_new("is_prime_large");
    bench_run(b, &_bench_is_prime_large, BENCH_ITERS);
    bench_report(b);

    b = bench_new("next_prime");
    bench_run(b, &_bench_next_prime, BENCH_ITERS);
    bench_report(b);

    b = bench_new("factor_small");
    bench_run(b, &_bench_factor_small, BENCH_ITERS);
    bench_report(b);

    b = bench_new("factor_large");
    bench_run(b, &_bench_factor_large, BENCH_ITERS);
    bench_report(b);

    b = bench_new("totient");
    bench_run(b, &_bench_totient, BENCH_ITERS);
    bench_report(b);

    b = bench_new("fibonacci");
    bench_run(b, &_bench_fibonacci, BENCH_ITERS);
    bench_report(b);

    b = bench_new("binomial");
    bench_run(b, &_bench_binomial, BENCH_ITERS);
    bench_report(b);

    return 0;
}

# ================================================================
# dsp benchmarks
# ================================================================

fn _bench_poly_blep_mid() {
    var half = f64_div(f64_from(1), f64_from(2));
    var dt = f64_div(f64_from(1), f64_from(100));
    poly_blep(half, dt);
    return 0;
}

fn _bench_poly_blep_edge() {
    var t = f64_div(f64_from(5), f64_from(1000));
    var dt = f64_div(f64_from(1), f64_from(100));
    poly_blep(t, dt);
    return 0;
}

fn _bench_angular_freq() {
    angular_frequency(f64_from(1000), f64_from(44100));
    return 0;
}

fn _bench_sanitize_finite() {
    sanitize_sample(f64_from(42));
    return 0;
}

fn _bench_sanitize_nan() {
    sanitize_sample(0x7FF8000000000000);
    return 0;
}

fn _bench_hypot() {
    f64_hypot(f64_from(3), f64_from(4));
    return 0;
}

fn _bench_lerp() {
    var half = f64_div(f64_from(1), f64_from(2));
    f64_lerp(f64_from(0), f64_from(100), half);
    return 0;
}

fn _bench_clamp() {
    f64_clamp(f64_from(5), f64_from(0), f64_from(10));
    return 0;
}

fn _bench_round() {
    f64_round(f64_div(f64_from(37), f64_from(10)));
    return 0;
}

fn _bench_sqrt() {
    f64_sqrt(f64_from(2));
    return 0;
}

fn _bench_abs() {
    f64_abs(f64_neg(f64_from(42)));
    return 0;
}

fn _bench_amp_to_db() {
    amplitude_to_db(f64_div(f64_from(1), f64_from(2)));
    return 0;
}

fn _bench_db_to_amp() {
    db_to_amplitude(f64_neg(f64_from(6)));
    return 0;
}

fn _bench_db_gain() {
    db_gain_factor(f64_from(12));
    return 0;
}

fn _bench_midi_to_freq() {
    midi_to_freq(f64_from(69));
    return 0;
}

fn _bench_freq_to_midi() {
    freq_to_midi(f64_from(440));
    return 0;
}

fn _bench_time_const() {
    time_constant(f64_from(10), f64_from(44100));
    return 0;
}

fn _bench_pan_center() {
    var l = alloc(8);
    var r = alloc(8);
    constant_power_pan(f64_from(0), l, r);
    return 0;
}

fn _bench_crossfade_mid() {
    var a = alloc(8);
    var b = alloc(8);
    equal_power_crossfade(f64_div(f64_from(1), f64_from(2)), a, b);
    return 0;
}

