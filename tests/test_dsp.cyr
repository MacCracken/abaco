# abaco dsp tests - full suite

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/tagged.cyr"
include "lib/assert.cyr"

include "src/core.cyr"
include "src/ntheory.cyr"
include "src/dsp.cyr"

# Helper: check f64 value is within tolerance of expected (as integers scaled by 1000)
# Multiply both by scale, convert to int, check abs diff <= tolerance
fn assert_f64_near(val, expected, tol_thousandths, name) {
    var scale = f64_from(1000);
    var vi = f64_to(f64_mul(val, scale));
    var ei = f64_to(f64_mul(expected, scale));
    var diff = vi - ei;
    if (diff < 0) { diff = 0 - diff; }
    assert(diff <= tol_thousandths, name);
    return 0;
}

fn test_angular_frequency() {
    var w0 = angular_frequency(f64_from(1000), f64_from(44100));
    var freq_back = f64_div(f64_mul(w0, f64_from(44100)), DSP_TAU);
    var fb_int = f64_to(freq_back);
    assert(fb_int >= 999, "angular_freq lo");
    assert(fb_int <= 1000, "angular_freq hi");
    assert_eq(f64_to(angular_frequency(f64_from(0), f64_from(44100))), 0, "angular_freq zero");
    return 0;
}

fn test_poly_blep() {
    var zero = f64_from(0);
    var half = f64_div(f64_from(1), f64_from(2));
    var dt = f64_div(f64_from(1), f64_from(100));
    assert_eq(f64_to(poly_blep(half, dt)), 0, "blep mid zero");
    assert_eq(f64_to(poly_blep(half, zero)), 0, "blep zero dt");
    assert(f64_eq(poly_blep(f64_div(dt, f64_from(2)), dt), zero) == 0, "blep near disc");
    return 0;
}

fn test_sanitize() {
    assert_eq(f64_to(sanitize_sample(f64_from(42))), 42, "sanitize normal");
    assert_eq(f64_to(sanitize_sample(0x7FF0000000000000)), 0, "sanitize inf");
    assert_eq(f64_to(sanitize_sample(0xFFF0000000000000)), 0, "sanitize neg inf");
    assert_eq(f64_to(sanitize_sample(0x7FF8000000000000)), 0, "sanitize nan");
    assert_eq(f64_to(sanitize_sample(f64_from(0))), 0, "sanitize zero");
    return 0;
}

fn test_clamp() {
    var lo = f64_from(0);
    var hi = f64_from(10);
    assert_eq(f64_to(f64_clamp(f64_from(5), lo, hi)), 5, "clamp mid");
    assert_eq(f64_to(f64_clamp(f64_neg(f64_from(3)), lo, hi)), 0, "clamp lo");
    assert_eq(f64_to(f64_clamp(f64_from(15), lo, hi)), 10, "clamp hi");
    return 0;
}

fn test_max_min() {
    assert_eq(f64_to(f64_max(f64_from(3), f64_from(7))), 7, "max(3,7)");
    assert_eq(f64_to(f64_min(f64_from(3), f64_from(7))), 3, "min(3,7)");
    assert_eq(f64_to(f64_max(f64_from(3), f64_from(3))), 3, "max(3,3)");
    assert_eq(f64_to(f64_min(f64_from(3), f64_from(3))), 3, "min(3,3)");
    return 0;
}

fn test_lerp() {
    var a = f64_from(0);
    var b = f64_from(100);
    assert_eq(f64_to(f64_lerp(a, b, f64_from(0))), 0, "lerp t=0");
    assert_eq(f64_to(f64_lerp(a, b, f64_from(1))), 100, "lerp t=1");
    assert_eq(f64_to(f64_lerp(a, b, f64_div(f64_from(1), f64_from(2)))), 50, "lerp t=0.5");
    return 0;
}

fn test_hypot() {
    assert_eq(f64_to(f64_hypot(f64_from(3), f64_from(4))), 5, "hypot(3,4)");
    assert_eq(f64_to(f64_hypot(f64_from(0), f64_from(5))), 5, "hypot(0,5)");
    assert_eq(f64_to(f64_hypot(f64_from(0), f64_from(0))), 0, "hypot(0,0)");
    return 0;
}

fn test_trunc_fract_round() {
    var v = f64_div(f64_from(37), f64_from(10));
    assert_eq(f64_to(f64_trunc(v)), 3, "trunc(3.7)");
    assert_eq(f64_to(f64_trunc(f64_neg(v))), 0 - 3, "trunc(-3.7)");
    assert_eq(f64_to(f64_fract(f64_from(5))), 0, "fract(5.0)");
    assert_eq(f64_to(f64_round(v)), 4, "round(3.7)");
    assert_eq(f64_to(f64_round(f64_div(f64_from(32), f64_from(10)))), 3, "round(3.2)");
    assert_eq(f64_to(f64_round(f64_neg(v))), 0 - 4, "round(-3.7)");
    return 0;
}

fn test_sign() {
    assert_eq(f64_to(f64_sign(f64_from(42))), 1, "sign(42)");
    assert_eq(f64_to(f64_sign(f64_neg(f64_from(7)))), 0 - 1, "sign(-7)");
    assert_eq(f64_to(f64_sign(f64_from(0))), 0, "sign(0)");
    return 0;
}

# ================================================================
# dB conversion tests
# ================================================================

fn test_db() {
    # amplitude_to_db(1.0) ~ 0
    assert_f64_near(amplitude_to_db(f64_from(1)), f64_from(0), 10, "db unity");
    # db_to_amplitude(0) ~ 1
    assert_f64_near(db_to_amplitude(f64_from(0)), f64_from(1), 10, "db_to_amp(0)");
    # amplitude_to_db(0.5) ~ -6.02
    var db_half = amplitude_to_db(f64_div(f64_from(1), f64_from(2)));
    var expect_neg6 = f64_neg(f64_div(f64_from(602), f64_from(100)));
    assert_f64_near(db_half, expect_neg6, 100, "db half amp");
    # db_to_amplitude(-6.02) ~ 0.5
    var amp_back = db_to_amplitude(expect_neg6);
    assert_f64_near(amp_back, f64_div(f64_from(1), f64_from(2)), 10, "amp from -6db");
    # amplitude_to_db(0) = NEG_INF
    var db_zero = amplitude_to_db(f64_from(0));
    assert_eq(db_zero, 0xFFF0000000000000, "db zero is neg inf");
    # amplitude_to_db(-1) = NEG_INF
    var db_neg = amplitude_to_db(f64_neg(f64_from(1)));
    assert_eq(db_neg, 0xFFF0000000000000, "db neg is neg inf");
    # db_gain_factor(12) ~ 1.995
    var gf = db_gain_factor(f64_from(12));
    assert_f64_near(gf, f64_div(f64_from(1995), f64_from(1000)), 10, "gain 12db");
    return 0;
}

# ================================================================
# MIDI tests
# ================================================================

fn test_midi() {
    # midi_to_freq(69) = 440
    assert_f64_near(midi_to_freq(DSP_A4_MIDI), DSP_A4_FREQ, 10, "midi A4");
    # midi_to_freq(60) ~ 261.63
    var c4 = midi_to_freq(f64_from(60));
    assert_f64_near(c4, f64_div(f64_from(26163), f64_from(100)), 100, "midi C4");
    # freq_to_midi(440) = 69
    assert_f64_near(freq_to_midi(DSP_A4_FREQ), DSP_A4_MIDI, 10, "freq A4");
    # Roundtrip: midi -> freq -> midi
    var note = f64_from(60);
    var freq = midi_to_freq(note);
    var back = freq_to_midi(freq);
    assert_f64_near(back, note, 1, "midi roundtrip");
    # freq_to_midi(0) = NEG_INF
    assert_eq(freq_to_midi(f64_from(0)), 0xFFF0000000000000, "freq zero neg inf");
    # freq_to_midi(-100) = NEG_INF
    assert_eq(freq_to_midi(f64_neg(f64_from(100))), 0xFFF0000000000000, "freq neg neg inf");
    return 0;
}

# ================================================================
# Time constant test
# ================================================================

fn test_time_constant() {
    # Fast attack (0.01ms): coefficient should be small (< 0.5)
    var c_fast = time_constant(f64_div(f64_from(1), f64_from(100)), f64_from(44100));
    var half = f64_div(f64_from(1), f64_from(2));
    assert(f64_lt(c_fast, half) == 1, "tc fast < 0.5");
    # Slow release (1000ms): coefficient should be high (> 0.99)
    var c_slow = time_constant(f64_from(1000), f64_from(44100));
    var high = f64_div(f64_from(99), f64_from(100));
    assert(f64_gt(c_slow, high) == 1, "tc slow > 0.99");
    return 0;
}

# ================================================================
# Panning tests
# ================================================================

fn test_pan() {
    var left = alloc(8);
    var right = alloc(8);
    # Center: L ~ R ~ 0.707
    constant_power_pan(f64_from(0), left, right);
    var l = load64(left);
    var r = load64(right);
    assert_f64_near(l, r, 10, "pan center L~R");
    assert_f64_near(l, DSP_FRAC_1_SQRT2, 10, "pan center ~0.707");
    # Full left: L ~ 1, R ~ 0
    constant_power_pan(f64_neg(f64_from(1)), left, right);
    assert_f64_near(load64(left), f64_from(1), 10, "pan left L~1");
    assert_f64_near(load64(right), f64_from(0), 10, "pan left R~0");
    # Full right: L ~ 0, R ~ 1
    constant_power_pan(f64_from(1), left, right);
    assert_f64_near(load64(left), f64_from(0), 10, "pan right L~0");
    assert_f64_near(load64(right), f64_from(1), 10, "pan right R~1");
    # Constant power: L^2 + R^2 ~ 1
    constant_power_pan(f64_div(f64_from(1), f64_from(2)), left, right);
    l = load64(left);
    r = load64(right);
    var power = f64_add(f64_mul(l, l), f64_mul(r, r));
    assert_f64_near(power, f64_from(1), 10, "pan constant power");
    # Clamp: pan=-2 same as pan=-1
    constant_power_pan(f64_neg(f64_from(2)), left, right);
    var l2 = load64(left);
    constant_power_pan(f64_neg(f64_from(1)), left, right);
    assert(f64_eq(l2, load64(left)) == 1, "pan clamp lo");
    return 0;
}

# ================================================================
# Crossfade tests
# ================================================================

fn test_crossfade() {
    var a = alloc(8);
    var b = alloc(8);
    # t=0: A=1, B=0
    equal_power_crossfade(f64_from(0), a, b);
    assert_f64_near(load64(a), f64_from(1), 10, "xfade t=0 A~1");
    assert_f64_near(load64(b), f64_from(0), 10, "xfade t=0 B~0");
    # t=1: A=0, B=1
    equal_power_crossfade(f64_from(1), a, b);
    assert_f64_near(load64(a), f64_from(0), 10, "xfade t=1 A~0");
    assert_f64_near(load64(b), f64_from(1), 10, "xfade t=1 B~1");
    # t=0.5: constant energy: A^2 + B^2 ~ 1
    equal_power_crossfade(f64_div(f64_from(1), f64_from(2)), a, b);
    var ga = load64(a);
    var gb = load64(b);
    var energy = f64_add(f64_mul(ga, ga), f64_mul(gb, gb));
    assert_f64_near(energy, f64_from(1), 10, "xfade constant energy");
    # Clamp: t=-1 same as t=0
    equal_power_crossfade(f64_neg(f64_from(1)), a, b);
    assert_f64_near(load64(a), f64_from(1), 10, "xfade clamp lo");
    return 0;
}

fn main() {
    alloc_init();
    println("=== abaco dsp tests ===");
    test_angular_frequency();
    test_poly_blep();
    test_sanitize();
    test_clamp();
    test_max_min();
    test_lerp();
    test_hypot();
    test_trunc_fract_round();
    test_sign();
    test_db();
    test_midi();
    test_time_constant();
    test_pan();
    test_crossfade();
    assert_summary();
    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
