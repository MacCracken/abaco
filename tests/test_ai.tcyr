    alloc_init();
    println("=== abaco ai tests ===");
    test_parse_what_is();
    test_parse_calculate();
    test_parse_percent_of();
    test_parse_standalone_percent();
    test_parse_conversion();
    test_parse_conversion_in();
    test_parse_currency();
    test_parse_currency_in();
    test_parse_how_much();
    test_parse_compute();
    test_parse_raw_expr();
    test_parse_number_only();
    test_parse_unparseable();
    test_history_push();
    test_history_limit();
    test_history_clear();
    test_currency_convert();
    test_ccy_parse_body();
    test_history_json_roundtrip();
    test_history_json_escapes();
    test_history_empty_json();
    test_security_percent_of_rejects_operators();
    test_security_percent_of_paren_injection();
    test_security_fetch_rejects_plaintext();
    test_security_fetch_rejects_crlf();
    test_security_fetch_accepts_localhost();
    assert_summary();
    return 0;
}

var rr = main();
syscall(SYS_EXIT, rr);
